# ── Gemini AI ──────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ── PostgreSQL (pick one approach) ────────────────────────────────────────────
# Option A — full DSN (overrides the individual vars below if set)
# DATABASE_URL=postgresql://postgres:password@localhost:5432/skillgapbuilder

# Option B — individual connection params (used when DATABASE_URL is not set)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=skillgapbuilder
DB_USER=postgres
DB_PASSWORD=your_postgres_password_here
